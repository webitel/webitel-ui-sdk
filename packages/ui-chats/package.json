{
	"name": "@webitel/ui-chats",
	"version": "0.1.35",
	"description": "Reusable Webitel Frontend Code for Chats UI",
	"workspaces": [
		"../../",
		"../styleguide",
		"../api-services"
	],
	"scripts": {
		"dev": "vite",
		"build:types": "vue-tsc -p ./tsconfig.build.json",
		"lint:fix": "npx biome check --write ./src",
		"biome:ci:gh": "biome ci ./src --reporter=github",
		"test:unit": "node -e \"process.exit(0)\"",
		"lint": "biome ci ./src",
		"test": "npm run test:unit",
		"ci:check": "npm run biome:ci:gh && npm run test:unit",
		"lint:package": "publint",
		"utils:publish": "npm publish --access public"
	},
	"dependencies": {
		"autolinker": "^4.1.5",
		"insert-text-at-cursor": "^0.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/node": "^24.10.0",
		"@vitejs/plugin-vue": "^6.0.1",
		"@vue/tsconfig": "^0.8.1",
		"mitt": "^3",
		"typescript": "~5.9.3",
		"vite": "npm:rolldown-vite@7.2.2",
		"vue": "^3.5",
		"publint": "^0.3.18",
		"vue-tsc": "^3.1.3"
	},
	"peerDependencies": {
		"@webitel/api-services": "^0.1.0",
		"@webitel/styleguide": "~26.2",
		"@webitel/ui-sdk": "~26.4",
		"mitt": "^3",
		"vue": "^3.5"
	},
	"type": "module",
	"main": "index.ts",
	"types": "index.d.ts",
	"files": [
		"src/*",
		"types/*",
		"Readme.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./src/index.ts"
		},
		"./ui": {
			"types": "./types/ui/index.d.ts",
			"import": "./src/ui/index.ts"
		}
	},
	"author": "webitel",
	"license": "ISC",
	"keywords": [
		"webitel",
		"webitel-ui"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/webitel/webitel-ui-sdk"
	},
	"engines": {
		"npm": ">=10",
		"node": ">=v22"
	}
}
