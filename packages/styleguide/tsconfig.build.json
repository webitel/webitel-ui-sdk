{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"emitDeclarationOnly": true,
		"declarationDir": "types",
		"rootDir": "./src",
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist",
		"strict": true,
		"moduleResolution": "node",
		"skipLibCheck": true
	},

	"include": [
		"src",
		"src/**/*.ts",
		"src/**/*.vue"
	],
	"exclude": [
		"node_modules",
		"dist",
		"src/assets/fonts"
	]
}
